# Backend / API base URL (no trailing slash)
REACT_APP_API_URL=http://application.almaarif.edu.ng

# Site title and branding name
REACT_APP_APP_NAME=Almaarif College of Health and Nursing Sciences

# Meta description for SEO
REACT_APP_APP_DESCRIPTION=Almaarif College of Health and Nursing Sciences launched in 2020

# Theme / branding colors (hex)
REACT_APP_THEME_PRIMARY=#DA0037
REACT_APP_THEME_SURFACE=#EDEDED

# Optional: theme-color meta tag (e.g. for mobile browser chrome)
REACT_APP_THEME_META_COLOR=#000000

# Branding: logo and favicon (URL or path from public, e.g. /logo.png)
# Leave empty to use bundled default logo
REACT_APP_LOGO_URL=https://storage.prismaforge.name.ng/alamaarif/static_assets/favicon/android-chrome-192x192.png
# Optional: secondary logo for carousel/banner (e.g. /logo-secondary.png)
REACT_APP_LOGO_SECONDARY_URL=
# Optional: favicon (e.g. /favicon.ico or full URL)
REACT_APP_FAVICON_URL=https://storage.prismaforge.name.ng/alamaarif/static_assets/favicon/favicon.ico

# Optional: branding taglines (used in print layout, scrolling banner, etc.)
REACT_APP_APP_TAGLINE=Health and Nursing Sciences, Potiskum
REACT_APP_APP_ADMISSION_TITLE=2026-2027 Admissions
